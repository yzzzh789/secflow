# Application
APP_ENV=production
SECFLOW_ROLE=control-plane
SECFLOW_HTTP_PORT=9090
SECFLOW_HOST_AGENT_URL=http://host.docker.internal:9091
SECFLOW_PYTHON_BIN=python3
PACKET_ANALYZER_DB_PATH=/app/data/packet_analyzer.sqlite
NIC_TRAFFIC_DB_PATH=/app/data/nic_traffic.sqlite
WEBSITE_SECURITY_STATE_PATH=/app/data/website_security_state.json

# Optional runtime settings
DEFAULT_NIC=eth0

# Thresholds (MB/s)
WARNING_MBPS=100
CRITICAL_MBPS=200
SUSTAINED_SECONDS=5

# Optional AI integration
AI_PROVIDER=ollama
AI_MODEL=qwen3:8b
